# Supabase Postgres — from Supabase dashboard -> Connect -> Connection string
# Direct (local dev): user is "postgres", host is db.YOUR_PROJECT.supabase.co:5432
# URL-encode special characters in the password (e.g. $ becomes %24)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT.supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT.supabase.co:5432/postgres"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="YOUR_PUBLISHABLE_KEY"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Invite-only access. Comma-separated emails allowed to sign up.
ALLOWED_SIGNUP_EMAILS="michael@example.com,dillon@example.com"
